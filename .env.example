# Copiá a `.env` en la raíz del proyecto. Valores en Supabase → Project Settings → API.

VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Mismo UUID que el club insertado en supabase/migrations/..._initial_schema.sql
VITE_CLUB_ID=11111111-1111-1111-1111-111111111111

# Opcional: para `npm run import-supabase` (si no están, el script usa las VITE_* de arriba).
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_CLUB_ID=

# Opcional: nombre del archivo en public/ (ej. mi-club.png). Por defecto logo.png
# VITE_APP_LOGO=logo.png
